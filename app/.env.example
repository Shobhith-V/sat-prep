# ── Supabase credentials ────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
#
# Local dev:  copy this file to `.env` and fill in the real values.
# Production: set these as GitHub repository → Settings → Secrets and variables
#             → Actions secrets of the SAME names (the deploy workflow reads them).
#
# The anon/publishable key is safe to expose in a frontend build — row-level
# security in the database is what actually protects user data. Never put the
# service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
